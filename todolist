"""
GitHub To-Do List PR Creator
-----------------------------
Creates a to-do list file and raises a Pull Request on GitHub using a Personal Access Token.

Requirements:
    pip install requests

Usage:
    Set the CONFIG section below, then run:
        python github_todo_pr.py
"""

import requests
import json
import base64
from datetime import datetime

# ─────────────────────────────────────────
# CONFIG — fill these in before running
# ─────────────────────────────────────────
GITHUB_TOKEN = "your_personal_access_token_here"
REPO_OWNER   = "your_github_username"
REPO_NAME    = "your_repository_name"
BASE_BRANCH  = "main"          # The branch you want to merge INTO
NEW_BRANCH   = "feature/add-todo-list"  # New branch that will be created
TODO_FILE    = "TODO.md"       # File that will be created/updated in the repo
# ─────────────────────────────────────────

HEADERS = {
    "Authorization": f"token {GITHUB_TOKEN}",
    "Accept": "application/vnd.github+json",
}
BASE_URL = f"https://api.github.com/repos/{REPO_OWNER}/{REPO_NAME}"


def collect_tasks() -> list[str]:
    """Interactively collect to-do tasks from the user."""
    print("\n📝 Enter your to-do tasks (press Enter with no input to finish):\n")
    tasks = []
    while True:
        task = input(f"  Task {len(tasks) + 1}: ").strip()
        if not task:
            break
        tasks.append(task)
    return tasks


def build_markdown(tasks: list[str]) -> str:
    """Build a Markdown to-do list."""
    today = datetime.now().strftime("%Y-%m-%d")
    lines = [f"# 📋 To-Do List\n", f"_Generated on {today}_\n\n## Tasks\n"]
    for task in tasks:
        lines.append(f"- [ ] {task}")
    return "\n".join(lines) + "\n"


def get_branch_sha(branch: str) -> str:
    """Get the latest commit SHA of a branch."""
    url = f"{BASE_URL}/git/ref/heads/{branch}"
    resp = requests.get(url, headers=HEADERS)
    resp.raise_for_status()
    sha = resp.json()["object"]["sha"]
    print(f"✅ Found base branch '{branch}' (SHA: {sha[:7]})")
    return sha


def create_branch(new_branch: str, sha: str) -> None:
    """Create a new branch from the given SHA."""
    url = f"{BASE_URL}/git/refs"
    payload = {"ref": f"refs/heads/{new_branch}", "sha": sha}
    resp = requests.post(url, headers=HEADERS, json=payload)
    if resp.status_code == 422:
        print(f"⚠️  Branch '{new_branch}' already exists, using it.")
    else:
        resp.raise_for_status()
        print(f"✅ Created branch '{new_branch}'")


def push_file(branch: str, file_path: str, content: str) -> None:
    """Create or update a file on the given branch."""
    url = f"{BASE_URL}/contents/{file_path}"
    encoded = base64.b64encode(content.encode()).decode()

    # Check if file already exists (needed for the SHA when updating)
    existing_sha = None
    check = requests.get(url, headers=HEADERS, params={"ref": branch})
    if check.status_code == 200:
        existing_sha = check.json()["sha"]

    payload = {
        "message": f"chore: add/update {file_path}",
        "content": encoded,
        "branch": branch,
    }
    if existing_sha:
        payload["sha"] = existing_sha

    resp = requests.put(url, headers=HEADERS, json=payload)
    resp.raise_for_status()
    print(f"✅ Pushed '{file_path}' to branch '{branch}'")


def create_pull_request(tasks: list[str]) -> str:
    """Open a Pull Request and return its URL."""
    url = f"{BASE_URL}/pulls"
    task_preview = "\n".join(f"- [ ] {t}" for t in tasks[:5])
    if len(tasks) > 5:
        task_preview += f"\n- _...and {len(tasks) - 5} more_"

    payload = {
        "title": "📋 Add To-Do List",
        "head": NEW_BRANCH,
        "base": BASE_BRANCH,
        "body": (
            "## Summary\n"
            "This PR adds a new `TODO.md` file with the following tasks:\n\n"
            f"{task_preview}\n\n"
            "_Auto-generated by github_todo_pr.py_"
        ),
    }
    resp = requests.post(url, headers=HEADERS, json=payload)
    resp.raise_for_status()
    pr_url = resp.json()["html_url"]
    print(f"✅ Pull Request created: {pr_url}")
    return pr_url


def main():
    print("=" * 50)
    print("   GitHub To-Do List PR Creator")
    print("=" * 50)

    # Step 1 — Collect tasks
    tasks = collect_tasks()
    if not tasks:
        print("❌ No tasks entered. Exiting.")
        return

    # Step 2 — Build Markdown content
    markdown = build_markdown(tasks)
    print(f"\n📄 Preview of {TODO_FILE}:\n{'-'*40}\n{markdown}{'-'*40}")

    # Step 3 — GitHub operations
    try:
        sha = get_branch_sha(BASE_BRANCH)
        create_branch(NEW_BRANCH, sha)
        push_file(NEW_BRANCH, TODO_FILE, markdown)
        pr_url = create_pull_request(tasks)

        print("\n🎉 Done! Your PR is ready for review:")
        print(f"   {pr_url}\n")

    except requests.HTTPError as e:
        print(f"\n❌ GitHub API error: {e.response.status_code} — {e.response.text}")


if __name__ == "__main__":
    main()
